# Server Configuration
# Port where the API will run (default: 3000)
PORT=3000

# DynamoDB Configuration
# DynamoDB endpoint (use http://localhost:8000 for local development)
DYNAMO_ENDPOINT=http://localhost:8000

# AWS Region for DynamoDB
DYNAMO_REGION=us-east-1

# AWS Credentials
# For local development, you can use fake credentials
# For production, use real AWS credentials or IAM roles
AWS_ACCESS_KEY_ID=fakeMyKeyId
AWS_SECRET_ACCESS_KEY=fakeSecretAccessKey

# DynamoDB Table Name
TABLE_NAME=MercadoGlobal
